{# Confluence Storage Format — KPI v8 — tableau unifié #}
{%- macro bar(r,w=100) -%}<div style="background:#dfe1e6;border-radius:3px;width:{{w}}px;height:14px;display:inline-block;vertical-align:middle"><div style="background:{%if r>=0.8%}#36B37E{%elif r>=0.5%}#FF991F{%else%}#DE350B{%endif%};border-radius:3px;height:14px;width:{{(r*w)|int}}px"></div></div> <strong style="color:{%if r>=0.8%}#36B37E{%elif r>=0.5%}#FF991F{%else%}#DE350B{%endif%}">{{(r*100)|round(0)|int}}&#160;%</strong>{%- endmacro -%}
{%- macro unified_tree(tags, lvl=0) -%}{%- for t in tags %}{%- if t.total_points>0 or t.children|selectattr("total_points","gt",0)|list %}{%- set act = (t.breakdown.in_progress or 0) + (t.breakdown.review or 0) + (t.breakdown.testing or 0) -%}<tr style="background:{%if lvl==0%}#f4f5f7;font-weight:bold{%elif lvl==1%}#fff{%else%}#fafbfc;color:#666{%endif%}"><td style="padding-left:{{lvl*18}}px">{%if lvl>0%}&#x2514; {%endif%}{{t.display or t.label}}</td><td style="text-align:center">{%if t.total_points>0%}{{t.weather.value}}{%endif%}</td><td>{%if t.total_points>0%}{{bar(t.score)}}{%endif%}</td><td style="text-align:center;background:#deebff">{%if t.total_points>0 and act%}{{act}}{%endif%}</td><td style="text-align:center;{%if t.breakdown.blocked>0%}background:#ffebe6;color:#DE350B;font-weight:bold{%endif%}">{{t.breakdown.blocked if t.breakdown.blocked>0}}</td></tr>{{unified_tree(t.children, lvl+1)}}{%endif%}{%endfor%}{%- endmacro -%}
<ac:structured-macro ac:name="info"><ac:rich-text-body><p>&#x1F4CA; <strong>Sprint {{r.sprint_number}} — S{{r.week_number}}/{{r.year}}</strong></p></ac:rich-text-body></ac:structured-macro>
<table style="width:100%;margin-bottom:12px"><tr><td style="padding:6px;font-size:12px"><strong>Début&#160;:</strong> {{r.project_start}}</td><td style="padding:6px;text-align:center">{{bar(r.time_progress, 300)}}</td><td style="padding:6px;text-align:right;font-size:12px"><strong style="color:{%if r.days_remaining<=30%}#DE350B{%elif r.days_remaining<=90%}#FF991F{%else%}#6B778C{%endif%}">Échéance&#160;: {{r.project_end}}</strong> <span style="color:#6B778C">({{r.days_remaining}}&#160;jours)</span></td></tr></table>
<h1 style="text-align:center">{{r.overall_weather.value}} {{ r.project_name or 'KPI' }} — {{(r.overall_completion*100)|round(1)}}&#160;%</h1>
<h2>&#x1F3AF; Story points</h2>
<table><tr><td style="padding:8px;text-align:center;background:#e3fcef"><strong style="font-size:18px">{{r.done_points}}</strong><br/>&#x2705; points terminés</td><td style="padding:8px;text-align:center;background:#fffae6"><strong style="font-size:18px">{{r.estimated_remaining}}</strong><br/>&#x1F504; restant projeté</td><td style="padding:8px;text-align:center;background:{%if r.overall_completion>=0.8%}#e3fcef{%elif r.overall_completion>=0.5%}#fffae6{%else%}#ffebe6{%endif%}"><strong style="font-size:22px">{{(r.overall_completion*100)|round(0)|int}}&#160;%</strong><br/>avancement</td>{%if r.raf%}<td style="padding:8px;text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}}"><strong style="font-size:18px">{{(r.raf.avg_velocity_per_week * r.raf.weeks_remaining)|round(0)|int}}</strong><br/>&#x1F4C8; capacité restante</td>{%endif%}</tr></table>
{%if r.raf%}<h2>&#x1F4CA; Synthèse</h2>
<table><tr><td style="padding:8px;text-align:center"><strong style="font-size:18px">{{r.raf.avg_velocity_per_week}}</strong><br/>points / semaine</td><td style="padding:8px;text-align:center"><strong style="font-size:18px">{{r.raf.velocity_needed_per_week}}</strong><br/>requis / semaine</td><td style="padding:8px;text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}}"><strong style="font-size:22px">{{'&#x2705;' if r.raf.on_track else '&#x1F6A8;'}}</strong></td></tr></table>
<h2>&#x1F4C8; Projection</h2>
<table><tr style="background:#f4f5f7"><th>Terminés</th><th>Restant projeté (+10&#160;%)</th><th>Semaines restantes</th><th>Capacité restante</th><th>Échéance</th><th>Besoin / semaine</th><th>Statut</th></tr>
<tr><td style="text-align:center;background:#e3fcef">{{r.done_points}}</td><td style="text-align:center;font-weight:bold">{{r.estimated_remaining}}</td><td style="text-align:center">{{r.raf.weeks_remaining}}</td><td style="text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}};font-weight:bold">{{(r.raf.avg_velocity_per_week * r.raf.weeks_remaining)|round(0)|int}}</td><td style="text-align:center">{{r.raf.project_deadline.strftime('%d/%m/%Y') if r.raf.project_deadline}}</td><td style="text-align:center;font-weight:bold">{{r.raf.velocity_needed_per_week}}</td><td style="text-align:center">{{'&#x2705;' if r.raf.on_track else '&#x1F6A8;'}}</td></tr></table>{%endif%}
<h2>&#x1F4CA; Avancement par domaine</h2>
<p style="font-size:11px;color:#5E6C84;border-left:3px solid #6554C0;padding:4px 8px"><strong>Score structurel&#160;:</strong> avancement pondéré par statut et sprint (Done = 100&#160;%, In Progress = 50&#160;%, Backlog = 10&#160;%).</p>
<table><thead><tr style="background:#f4f5f7"><th>Domaine</th><th>Météo</th><th>Score structurel</th><th style="background:#deebff">En cours</th><th style="background:#ffebe6">Bloqués</th></tr></thead><tbody>{{unified_tree(r.tag_scores)}}</tbody></table>
{%if r.blocked_stories%}<h2>&#x1F6A8; Bloqués ({{r.blocked_stories|length}} — {{r.blocked_stories|sum(attribute='story_points')}} points)</h2><table><tr style="background:#f4f5f7"><th>Clé</th><th>Résumé</th><th>Points</th><th>Assigné</th></tr>{%for s in r.blocked_stories%}<tr style="background:#ffebe6"><td><a href="{{r.jira_base_url}}/browse/{{s.key}}">{{s.key}}</a></td><td>{{s.summary}}</td><td>{{s.story_points}}</td><td>{{s.assignee or '—'}}</td></tr>{%endfor%}</table>{%endif%}
<p style="color:#999;font-size:10px">KPI v8</p>
