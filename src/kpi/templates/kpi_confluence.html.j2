{# Confluence Storage Format — KPI v8 — tableau unifié #}
{%- macro bar(r,w=100) -%}<div style="background:#dfe1e6;border-radius:3px;width:{{w}}px;height:14px;display:inline-block;vertical-align:middle"><div style="background:{%if r>=0.5%}#36B37E{%elif r>=0.25%}#FF991F{%else%}#DE350B{%endif%};border-radius:3px;height:14px;width:{{(r*w)|int}}px"></div></div> <strong style="color:{%if r>=0.5%}#36B37E{%elif r>=0.25%}#FF991F{%else%}#DE350B{%endif%}">{{(r*100)|round(0)|int}}&#160;%</strong>{%- endmacro -%}
{%- macro unified_tree(tags, lvl=0) -%}{%- for t in tags %}{%- if t.total_points>0 or t.children|selectattr("total_points","gt",0)|list %}<tr style="background:{%if lvl==0%}#f4f5f7;font-weight:bold{%elif lvl==1%}#fff{%else%}#fafbfc;color:#666{%endif%}"><td style="padding-left:{{lvl*18}}px">{%if lvl>0%}&#x2514; {%endif%}{{t.display or t.label}}</td><td style="text-align:center">{%if t.total_points>0%}{{t.weather.value}}{%endif%}</td><td>{%if t.total_points>0%}{{bar(t.score)}}{%endif%}</td><td style="text-align:center;{%if t.breakdown.blocked>0%}background:#ffebe6;color:#DE350B;font-weight:bold{%endif%}">{{t.breakdown.blocked if t.breakdown.blocked>0}}</td></tr>{{unified_tree(t.children, lvl+1)}}{%endif%}{%endfor%}{%- endmacro -%}
<ac:structured-macro ac:name="info"><ac:rich-text-body><p>&#x1F4CA; <strong>Sprint {{r.sprint_number}} — S{{r.week_number}}/{{r.year}}</strong></p></ac:rich-text-body></ac:structured-macro>
<table style="width:100%;margin-bottom:12px"><tr><td style="padding:12px;text-align:center;width:50%"><div style="font-size:10px;color:#6B778C;text-transform:uppercase;margin-bottom:4px">% temps écoulé</div><div style="font-size:28px;font-weight:bold">{{(r.time_progress*100)|round(0)|int}}&#160;%</div><div style="margin-top:4px">{{bar(r.time_progress, 150)}}</div><table style="width:100%;margin-top:8px"><tr><td style="text-align:center;background:#f4f5f7;padding:6px;border-radius:3px"><strong>{{r.business_days_elapsed}}</strong><br/><span style="font-size:9px;color:#6B778C">jours ouvrés écoulés</span></td><td style="text-align:center;background:{%if r.business_days_remaining<=40%}#ffebe6{%elif r.business_days_remaining<=80%}#fffae6{%else%}#f4f5f7{%endif%};padding:6px;border-radius:3px"><strong>{{r.business_days_remaining}}</strong><br/><span style="font-size:9px;color:#6B778C">jours ouvrés restants</span></td></tr></table><div style="font-size:9px;color:#6B778C;margin-top:4px">{{r.project_start}} → {{r.project_end}}</div></td><td style="padding:12px;text-align:center;width:50%"><div style="font-size:10px;color:#6B778C;text-transform:uppercase;margin-bottom:4px">Score global d'avancement au {{r.generated_at.strftime('%d/%m/%Y')}}</div><div style="font-size:28px;font-weight:bold">{{(r.score_global_date*100)|round(0)|int}}&#160;%</div><div style="margin-top:4px">{{bar(r.score_global_date, 150)}}</div><table style="width:100%;margin-top:8px"><tr><td style="text-align:center;background:#e3fcef;padding:6px;border-radius:3px"><strong>{{r.done_points}}</strong><br/><span style="font-size:9px;color:#6B778C">pts terminés</span></td><td style="text-align:center;background:#f4f5f7;padding:6px;border-radius:3px"><strong>{{r.total_points}}</strong><br/><span style="font-size:9px;color:#6B778C">pts total</span></td></tr></table><div style="font-size:9px;color:#6B778C;margin-top:4px">{{r.overall_weather.value}} score pondéré — ratio brut&#160;: {{(r.overall_completion*100)|round(0)|int}}&#160;%</div></td></tr></table>
<p style="font-size:11px;color:#5E6C84;border-left:3px solid #6554C0;padding:4px 8px"><strong>Score global</strong> ≠ ratio terminé/total ({{(r.overall_completion*100)|round(0)|int}}&#160;%).<ul><li>Livré = 100&#160;% &#x2022; En cours = 50&#160;% &#x2022; Non démarré = 0&#160;%</li><li>Ne compte que les livrables planifiés jusqu'à la période en cours</li><li>Mesure l'avancement réel par rapport aux jalons prévus à date</li></ul></p>
<h2>&#x1F3AF; Story points</h2>
<table><tr><td style="padding:8px;text-align:center;background:#e3fcef"><strong style="font-size:18px">{{r.done_points}}</strong><br/>&#x2705; points terminés</td><td style="padding:8px;text-align:center;background:#fffae6"><strong style="font-size:18px">{{r.estimated_remaining}}</strong><br/>&#x1F504; restant projeté</td><td style="padding:8px;text-align:center;background:#ffebe6"><strong style="font-size:18px">{{r.blocked_stories|length}}</strong><br/>&#x1F6A8; bloqués</td>{%if r.raf%}<td style="padding:8px;text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}}"><strong style="font-size:18px">{{(r.raf.avg_velocity_per_week * r.raf.weeks_remaining)|round(0)|int}}</strong><br/>&#x1F4C8; capacité restante</td>{%endif%}</tr></table>
{%if r.raf%}<h2>&#x1F4CA; Synthèse</h2>
<table><tr><td style="padding:8px;text-align:center"><strong style="font-size:18px">{{r.raf.avg_velocity_per_week}}</strong><br/>points / semaine</td><td style="padding:8px;text-align:center"><strong style="font-size:18px">{{r.raf.velocity_needed_per_week}}</strong><br/>requis / semaine</td><td style="padding:8px;text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}}"><strong style="font-size:22px">{{'&#x2705;' if r.raf.on_track else '&#x1F6A8;'}}</strong></td></tr></table>
<h2>&#x1F4C8; Projection</h2>
<table><tr style="background:#f4f5f7"><th>Terminés</th><th>Restant projeté (+10&#160;%)</th><th>Semaines restantes</th><th>Capacité restante</th><th>Échéance</th><th>Besoin / semaine</th><th>Statut</th></tr>
<tr><td style="text-align:center;background:#e3fcef">{{r.done_points}}</td><td style="text-align:center;font-weight:bold">{{r.estimated_remaining}}</td><td style="text-align:center">{{r.raf.weeks_remaining}}</td><td style="text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}};font-weight:bold">{{(r.raf.avg_velocity_per_week * r.raf.weeks_remaining)|round(0)|int}}</td><td style="text-align:center">{{r.raf.project_deadline.strftime('%d/%m/%Y') if r.raf.project_deadline}}</td><td style="text-align:center;font-weight:bold">{{r.raf.velocity_needed_per_week}}</td><td style="text-align:center">{{'&#x2705;' if r.raf.on_track else '&#x1F6A8;'}}</td></tr></table>{%endif%}
<h2>&#x1F4CA; Avancement par domaine</h2>
<p style="font-size:11px;color:#5E6C84;border-left:3px solid #6554C0;padding:4px 8px"><strong>Score structurel</strong> ≠ ratio terminé/total.<ul><li>Livré = 100&#160;% &#x2022; En cours = 50&#160;% &#x2022; Non démarré = 0&#160;%</li><li>Pondéré par le poids en story points de chaque livrable</li><li>Reflète l'avancement réel, pas seulement le nombre de livrables terminés</li></ul></p>
<table><thead><tr style="background:#f4f5f7"><th>Domaine</th><th>Météo</th><th>Score structurel</th><th style="background:#ffebe6">US bloquées</th></tr></thead><tbody>{{unified_tree(r.tag_scores)}}</tbody></table>
{%if r.blocked_stories%}<h2>&#x1F6A8; User stories bloquées ({{r.blocked_stories|length}} — {{r.blocked_stories|sum(attribute='story_points')}} points)</h2><table><tr style="background:#f4f5f7"><th>Clé</th><th>Résumé</th><th>Points</th><th>Assigné</th></tr>{%for s in r.blocked_stories%}<tr style="background:#ffebe6"><td><a href="{{r.jira_base_url}}/browse/{{s.key}}">{{s.key}}</a></td><td>{{s.summary}}</td><td>{{s.story_points}}</td><td>{{s.assignee or '—'}}</td></tr>{%endfor%}</table>{%endif%}
<p style="color:#999;font-size:10px">KPI v8</p>
