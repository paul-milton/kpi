{# Confluence Storage Format — KPI v7 — points only, no user stories row #}
{%- macro bar(r,w=100) -%}<div style="background:#dfe1e6;border-radius:3px;width:{{w}}px;height:14px;display:inline-block;vertical-align:middle"><div style="background:{%if r>=0.8%}#36B37E{%elif r>=0.5%}#FF991F{%else%}#DE350B{%endif%};border-radius:3px;height:14px;width:{{(r*w)|int}}px"></div></div> <strong style="color:{%if r>=0.8%}#36B37E{%elif r>=0.5%}#FF991F{%else%}#DE350B{%endif%}">{{(r*100)|round(0)|int}}%</strong>{%- endmacro -%}
{%- macro tree(kpis,lvl=0) -%}{%- for k in kpis %}{%- if k.total_points>0 or k.children|selectattr("total_points","gt",0)|list %}<tr style="background:{%if lvl==0%}#f4f5f7;font-weight:bold{%elif lvl==1%}#fff{%else%}#fafbfc;color:#666{%endif%}"><td style="padding-left:{{lvl*18}}px">{%if lvl>0%}└ {%endif%}{{k.display}}</td><td style="text-align:center">{%if k.total_points>0%}{{k.weather}}{%endif%}</td><td style="text-align:center;background:#e3fcef">{%if k.effective_done%}{{k.effective_done}}{%if k.prorata_points%} <span style="color:#888;font-size:10px">(+{{k.prorata_points}})</span>{%endif%}{%endif%}</td><td style="text-align:center;color:#FF991F;font-weight:bold">{{k.estimated_remaining if k.estimated_remaining else ''}}</td><td style="text-align:center;color:#888;font-style:italic">{{k.estimated_project_total if k.estimated_project_total>0 else '—'}}</td><td>{%if k.total_points>0%}{{bar(k.completion_ratio)}}{%endif%}</td><td style="text-align:center;background:#deebff">{{k.breakdown.active if k.total_points>0}}</td><td style="text-align:center;{%if k.breakdown.blocked>0%}background:#ffebe6;color:#DE350B;font-weight:bold{%endif%}">{{k.breakdown.blocked if k.breakdown.blocked>0}}</td></tr>{{tree(k.children,lvl+1)}}{%endif%}{%endfor%}{%- endmacro -%}
<ac:structured-macro ac:name="info"><ac:rich-text-body><p>📊 <strong>Sprint {{r.sprint_number}} — sem. {{r.sprint_week}}/{{r.sprint_duration_weeks}} — S{{r.week_number}}/{{r.year}}</strong></p></ac:rich-text-body></ac:structured-macro>
<h1 style="text-align:center">{{r.overall_weather.value}} KPI — {{(r.overall_completion*100)|round(1)}}%</h1>
<h2>🎯 story points</h2>
<table><tr><td style="padding:8px;text-align:center;background:#e3fcef"><strong style="font-size:18px">{{r.effective_done}}</strong>{%if r.prorata_points%}<span style="font-size:11px;color:#6B778C"> (+{{r.prorata_points}})</span>{%endif%}<br/>✅ pts faits</td><td style="padding:8px;text-align:center;background:#fffae6"><strong style="font-size:18px">{{r.total_points-r.effective_done}}</strong><br/>🔄 restant estimé</td><td style="padding:8px;text-align:center;background:{%if r.overall_completion>=0.8%}#e3fcef{%elif r.overall_completion>=0.5%}#fffae6{%else%}#ffebe6{%endif%}"><strong style="font-size:22px">{{(r.overall_completion*100)|round(0)|int}}%</strong><br/>avancement</td>{%if r.raf%}<td style="padding:8px;text-align:center;background:#eae6ff"><strong style="font-size:18px">{{r.raf.projected_total}}</strong><br/>📈 projeté</td>{%endif%}</tr></table>
<h2>📊 synthèse</h2>
<table><tr>{%if r.raf%}<td style="padding:8px;text-align:center"><strong style="font-size:18px">{{r.raf.avg_velocity_per_week}}</strong><br/>pts/sem.</td><td style="padding:8px;text-align:center"><strong style="font-size:18px">{{r.raf.velocity_needed_per_week}}</strong><br/>requis/sem.</td><td style="padding:8px;text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}}"><strong style="font-size:22px">{{'✅' if r.raf.on_track else '🚨'}}</strong></td>{%endif%}</tr></table>
{%if r.raf%}<h2>📈 projection</h2>
<table><tr style="background:#f4f5f7"><th>total</th><th>faits</th><th>reste</th><th>sem. rest.</th><th>projeté</th><th>deadline</th><th>besoin/sem.</th><th>statut</th></tr>
<tr><td style="text-align:center">{{r.total_points}}</td><td style="text-align:center;background:#e3fcef">{{r.effective_done}}</td><td style="text-align:center;font-weight:bold">{{r.raf.remaining_points}}</td><td style="text-align:center">{{r.raf.weeks_remaining}}</td><td style="text-align:center;background:{{'#e3fcef' if r.raf.on_track else '#ffebe6'}};font-weight:bold">{{r.raf.projected_total}}</td><td style="text-align:center">{{r.raf.project_deadline.strftime('%d/%m/%Y') if r.raf.project_deadline}}</td><td style="text-align:center;font-weight:bold">{{r.raf.velocity_needed_per_week}}</td><td style="text-align:center">{{'✅' if r.raf.on_track else '🚨'}}</td></tr></table>{%endif%}
<h2>📊 détail</h2><table><thead><tr style="background:#f4f5f7"><th>domaine</th><th>météo</th><th style="background:#e3fcef">pts faits</th><th>restant est.</th><th>est. projet</th><th>avancement</th><th style="background:#deebff">actif</th><th style="background:#ffebe6">bloqué</th></tr></thead><tbody>{{tree(r.dimension_kpis)}}</tbody></table>
{%if r.current_sprint_stories%}<h2>🏃 en cours sprint {{r.sprint_number}}</h2><table><tr style="background:#f4f5f7"><th>clé</th><th>résumé</th><th>statut</th><th>pts</th><th>assigné</th></tr>{%for s in r.current_sprint_stories%}<tr><td><a href="{{r.jira_base_url}}/browse/{{s.key}}">{{s.key}}</a></td><td>{{s.summary}}</td><td>{{s.status.value}}</td><td>{{s.story_points}}</td><td>{{s.assignee or '—'}}</td></tr>{%endfor%}</table>{%endif%}
{%if r.blocked_stories%}<h2>🚨 bloquées</h2><table><tr style="background:#f4f5f7"><th>clé</th><th>résumé</th><th>pts</th><th>assigné</th></tr>{%for s in r.blocked_stories%}<tr style="background:#ffebe6"><td><a href="{{r.jira_base_url}}/browse/{{s.key}}">{{s.key}}</a></td><td>{{s.summary}}</td><td>{{s.story_points}}</td><td>{{s.assignee or '—'}}</td></tr>{%endfor%}</table>{%endif%}
{%if r.unidentified_stories%}<h2>❓ orphelines</h2><table><tr style="background:#f4f5f7"><th>clé</th><th>résumé</th><th>statut</th><th>pts</th></tr>{%for s in r.unidentified_stories%}<tr><td><a href="{{r.jira_base_url}}/browse/{{s.key}}">{{s.key}}</a></td><td>{{s.summary}}</td><td>{{s.status.value}}</td><td>{{s.story_points}}</td></tr>{%endfor%}</table>{%endif%}
<p style="color:#999;font-size:10px">kpi v7</p>
